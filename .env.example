# Server
PORT=3000
WEBHOOK_SECRET=your_shared_secret_here

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Kantata
KANTATA_TOKEN=your_kantata_personal_access_token

# Salesforce (write-back + backfill — NOT YET IMPLEMENTED, see PRODUCTION_CHECKLIST.md)
# SF_LOGIN_URL=https://login.salesforce.com
# SF_USERNAME=your_sf_username
# SF_PASSWORD=your_sf_password
# SF_SECURITY_TOKEN=your_sf_security_token
# SF_CONSUMER_KEY=your_connected_app_consumer_key
# SF_CONSUMER_SECRET=your_connected_app_consumer_secret

# Email notifications (leave blank to log-only in dev; all 4 required for live alerts)
NOTIFY_EMAIL_TO=ryan@engage2learn.org
NOTIFY_EMAIL_FROM=noreply@engage2learn.org
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=your_smtp_username
NOTIFY_SMTP_PASS=your_smtp_app_password

# Google
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-service-account.json
GOOGLE_DRIVE_TEMPLATE_FOLDER_ID=the_drive_folder_id_to_copy_from
GOOGLE_DRIVE_PARENT_FOLDER_ID=the_drive_folder_id_where_new_folders_are_created
